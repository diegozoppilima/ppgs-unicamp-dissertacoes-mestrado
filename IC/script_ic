    rank = row_number(),
    freq_rel = n / total_tokens,
    termo = str_to_title(palavra)
  ) %>%
  select(rank, termo, n, freq_rel)

gt_unigramas <- tabela_unigramas %>%
  slice_head(n = 30) %>%
