# 3) Tokenização dos títulos (unigramas)
titulos_tokens <- base_de_dados %>%
  select(id, titulo, ano_de_defesa, periodo) %>%
  filter(!is.na(titulo)) %>%
  mutate(
    titulo = str_to_lower(titulo),
    titulo = stri_trans_general(titulo, "Latin-ASCII")
  ) %>%
  unnest_tokens(palavra, titulo) %>%
  filter(
    !palavra %in% stop_custom,
    !str_detect(palavra, "^[0-9]+$"),
    nchar(palavra) > 1
  )

# 4) Frequências de unigramas e tabela (Top 30)
