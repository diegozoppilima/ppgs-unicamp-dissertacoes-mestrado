# 15) Rede de coocorrência por período (SEM widyr)
#     - constrói arestas por doc/periodo (pares não direcionais)
#     - constrói nós por periodo com freq e nº de docs
# Base sem duplicar a mesma palavra por doc/periodo
base_palavras_nodup <- base_palavras %>%
  distinct(periodo, id, palavras_chave)

# ARESTAS por período
edges_periodo <- base_palavras_nodup %>%
  group_by(periodo, id) %>%
  summarise(palavras = list(palavras_chave), .groups = "drop") %>%
  mutate(
    pares = purrr::map(palavras, ~ {
      v <- sort(unique(.x))
      if (length(v) > 1) combn(v, 2, simplify = FALSE) else NULL
    })
  ) %>%
  select(-palavras) %>%
  unnest(pares) %>%
  mutate(
    source = purrr::map_chr(pares, 1),
    target = purrr::map_chr(pares, 2)
  ) %>%
  count(periodo, source, target, name = "weight")

# NÓS por período
nodes_periodo <- base_palavras %>%
  group_by(periodo, palavras_chave) %>%
  summarise(freq = n(), n_docs = n_distinct(id), .groups = "drop") %>%
  transmute(
    periodo,
    id    = palavras_chave,   # id = a própria palavra
    label = palavras_chave,   # label para exibição
    freq,
    n_docs
  )

