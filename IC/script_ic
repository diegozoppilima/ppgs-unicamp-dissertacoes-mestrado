# 8) Coocorrência de palavras por título (arestas p/ Gephi)
edges_raw <- pairwise_count(
  tbl     = titulos_tokens %>% distinct(titulo_id, palavra),
  item    = palavra,
  feature = titulo_id,
  sort    = TRUE,
  upper   = FALSE
)

MIN_WEIGHT <- 2

edges_gephi <- edges_raw %>%
  filter(n >= MIN_WEIGHT) %>%
  transmute(Source = item1, Target = item2, Weight = n) %>%
  filter(!is.na(Source), !is.na(Target))

# 9) Nós (palavras) + métricas básicas e grafo
nodes_freq <- titulos_tokens %>%
  count(palavra, name = "Freq")

vertices <- tibble(name = unique(c(edges_gephi$Source, edges_gephi$Target))) %>%
  mutate(name = as.character(name))

nodes_tbl <- vertices %>%
  left_join(nodes_freq, by = c("name" = "palavra")) %>%
  mutate(Freq = coalesce(Freq, 0L))

g <- igraph::graph_from_data_frame(
  d = edges_gephi %>% rename(from = Source, to = Target),
  directed = FALSE,
  vertices = nodes_tbl
)

nodes_gephi <- nodes_tbl %>%
  transmute(
    Id = name,
    Label = stringr::str_to_title(name),
    Freq = Freq,
    degree = igraph::degree(g),
    strength = igraph::strength(g, weights = igraph::E(g)$Weight)
  )

