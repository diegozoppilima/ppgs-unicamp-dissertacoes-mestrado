# 22) REDE DOCENTE (Orientador x Avaliadores) — base_orientadores
#     - Usa colunas já em snake_case: id, orientador, avaliador_1..3
# 22.1) Limpeza e pivotagem (gera base longa só com avaliadores válidos)
base_rede_docente <- base_orientadores %>%
  transmute(
    id,
    orientador  = stringr::str_squish(orientador),
    avaliador_1 = stringr::str_squish(as.character(avaliador_1)),
    avaliador_2 = stringr::str_squish(as.character(avaliador_2)),
    avaliador_3 = stringr::str_squish(as.character(avaliador_3))
  ) %>%
  dplyr::mutate(
    dplyr::across(
      dplyr::starts_with("avaliador"),
      ~ .x |> dplyr::na_if("") |> dplyr::na_if("NA") |> dplyr::na_if("Na") |>
        dplyr::na_if("N/A") |> dplyr::na_if("-")  |> dplyr::na_if("—")  |> dplyr::na_if("–")
    )
  ) %>%
  tidyr::pivot_longer(
    cols           = dplyr::starts_with("avaliador"),
    names_to       = "tipo",
    values_to      = "avaliador",
    values_drop_na = TRUE
  )

# 22.2) Arestas (sem direção), peso = nº de dissertações em comum
edges_docentes <- base_rede_docente %>%
  dplyr::transmute(source = orientador, target = avaliador) %>%
  dplyr::filter(source != target) %>%                 # remove auto-laços por segurança
  dplyr::group_by(source, target) %>%
  dplyr::summarise(weight = dplyr::n(), .groups = "drop") %>% # colapsa duplicatas
  dplyr::arrange(dplyr::desc(weight), source, target)

# 22.3) Nós (Id, Label, Tipo = orientador se já apareceu como source; senão, avaliador)
nodes_docentes <- edges_docentes %>%
  dplyr::select(source, target) %>%
  tidyr::pivot_longer(cols = dplyr::everything(), values_to = "nome") %>%
  dplyr::distinct(nome) %>%
  dplyr::mutate(
    Id    = nome,
    Label = nome,
    Tipo  = dplyr::if_else(nome %in% edges_docentes$source, "orientador", "avaliador")
  ) %>%
  dplyr::select(Id, Label, Tipo) %>%
  dplyr::arrange(Tipo, Label)

