base_de_dados <- read_xlsx("dissertacoes_ppgs_unicamp.xlsx")

base_de_dados <- clean_names(base_de_dados) %>%
  mutate(
    periodo = case_when(
      ano_de_defesa >= 1974 & ano_de_defesa <= 1983 ~ "1974–1983",
      ano_de_defesa >= 1984 & ano_de_defesa <= 1993 ~ "1984–1993",
      ano_de_defesa >= 1994 & ano_de_defesa <= 2003 ~ "1994–2003",
      ano_de_defesa >= 2004 & ano_de_defesa <= 2013 ~ "2004–2013",
      ano_de_defesa >= 2014 & ano_de_defesa <= 2024 ~ "2014–2024",
      TRUE ~ NA_character_
    )
  )

# 1.1) Base anual COMPLETA (1974–2024) + percentuais GLOBAIS
# Requer: base_de_dados carregada (Bloco 1), e pacotes tidyverse/gt/scales
base_ano <- base_de_dados %>%
  mutate(ano_de_defesa = as.integer(ano_de_defesa)) %>%
  count(ano_de_defesa, name = "n") %>%
  complete(ano_de_defesa = 1974:2024, fill = list(n = 0)) %>%
  arrange(ano_de_defesa)

total_corpus <- sum(base_ano$n)

base_ano <- base_ano %>%
  mutate(
    freq_pct_global      = 100 * n / total_corpus,
    freq_pct_acum_global = 100 * cumsum(n) / total_corpus
  )

# 1.2) Função: tabela gt para um intervalo (percentuais GLOBAIS)
gt_tabela_periodo_global <- function(df_global, inicio, fim,
                                     titulo = NULL,
                                     incluir_zeros = TRUE) {
  
  df_periodo <- df_global %>%
    filter(ano_de_defesa >= inicio, ano_de_defesa <= fim) %>%
    { if (!incluir_zeros) filter(., n > 0) else . } %>%
    transmute(
      Ano                                 = as.character(ano_de_defesa),
      `Número de dissertações`            = n,
      `Frequência relativa (%)`           = round(freq_pct_global, 1),
      `Frequência relativa acumulada (%)` = round(freq_pct_acum_global, 1)
    )
  
  total_periodo_n   <- sum(df_periodo$`Número de dissertações`)
  total_periodo_pct <- round(100 * total_periodo_n / total_corpus, 1)
  acum_no_fim       <- dplyr::last(df_periodo$`Frequência relativa acumulada (%)`)
  
  total_row <- tibble(
    Ano                                 = "TOTAL",
    `Número de dissertações`            = total_periodo_n,
    `Frequência relativa (%)`           = total_periodo_pct,
    `Frequência relativa acumulada (%)` = acum_no_fim
  )
  
  bind_rows(df_periodo, total_row) %>%
    gt() %>%
    cols_align("center", everything()) %>%
    fmt_number(columns = `Número de dissertações`, decimals = 0, use_seps = TRUE) %>%
    fmt_number(columns = c(`Frequência relativa (%)`, `Frequência relativa acumulada (%)`),
               decimals = 1, use_seps = TRUE) %>%
    tab_style(style = cell_text(weight = "bold"),
              locations = cells_body(rows = Ano == "TOTAL")) %>%
    opt_stylize(style = 6, color = "gray") %>%
    opt_row_striping() %>%
    opt_table_outline() %>%
    tab_options(table.align = "left")
}

