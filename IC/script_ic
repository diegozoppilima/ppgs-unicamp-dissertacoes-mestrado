# 5) Bigramas: geração, limpeza e frequência
bigrams <- base_de_dados %>%
  select(titulo, ano_de_defesa) %>%
  filter(!is.na(titulo)) %>%
  mutate(
    titulo = str_to_lower(titulo),
    titulo = stri_trans_general(titulo, "Latin-ASCII")
  ) %>%
  unnest_tokens(bigrama, titulo, token = "ngrams", n = 2)

bigrams_limpos <- bigrams %>%
  tidyr::separate(bigrama, c("p1", "p2"), sep = " ") %>%
  filter(
    !p1 %in% stop_custom, !p2 %in% stop_custom,
    !is.na(p1), !is.na(p2),
    nchar(p1) > 1, nchar(p2) > 1,
    !str_detect(p1, "^[0-9]+$"),
    !str_detect(p2, "^[0-9]+$")
  ) %>%
  tidyr::unite("bigrama", p1, p2, sep = " ")

bigrams_freq <- bigrams_limpos %>%
  count(bigrama, sort = TRUE, name = "n")

total_bigrams <- sum(bigrams_freq$n)

tabela_bigrams_bruta <- bigrams_freq %>%
  mutate(
    rank = row_number(),
    freq_rel = n / total_bigrams,
    bigrama = str_to_title(bigrama)
  ) %>%
  select(rank, bigrama, n, freq_rel)

