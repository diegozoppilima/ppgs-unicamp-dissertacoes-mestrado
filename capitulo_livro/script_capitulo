# 2) Funções auxiliares
normalizar_base <- function(x) {
  x %>%
    str_to_lower() %>%
    stri_trans_general("Latin-ASCII") %>%
    str_replace_all("-", "_") %>%
    str_replace_all("['`']", " ") %>%
    str_replace_all("&", " ") %>%
    str_replace_all("[^[:alnum:]_]+", " ") %>%
    str_squish()
}

aplicar_mapa_substituicoes <- function(texto, mapa) {
  if (length(mapa) == 0) return(texto)
  chaves <- names(mapa)[order(nchar(names(mapa)), decreasing = TRUE)]
  purrr::reduce(
    chaves,
    .init = texto,
    .f = function(txt, chave) {
      padrao <- chave %>%
        str_replace_all("([\\^$.|?*+(){}\\[\\]\\\\])", "\\\\\\1") %>%
        str_replace_all("\\s+", "\\\\s+")
      padrao <- paste0("(?<![[:alnum:]_])", padrao, "(?![[:alnum:]_])")
      str_replace_all(txt, regex(padrao, ignore_case = FALSE), mapa[[chave]])
    }
  )
}

formatar_token <- function(x) {
  str_to_title(str_replace_all(x, "_", " "))
}

criar_tabela_freq <- function(df, termo_col, n_top = 30, termo_label = "Termo") {
  termo_col <- rlang::ensym(termo_col)
  total_n <- sum(df$n)
  df %>%
    arrange(desc(n), !!termo_col) %>%
    mutate(
      rank      = row_number(),
      freq_rel  = n / total_n,
      termo_fmt = formatar_token(!!termo_col)
    ) %>%
    select(rank, termo_fmt, n, freq_rel) %>%
    slice_head(n = n_top) %>%
    gt() %>%
    fmt_percent(columns = freq_rel, decimals = 2) %>%
    cols_label(
      rank      = "Posição",
      termo_fmt = termo_label,
      n         = "Frequência",
      freq_rel  = "Frequência relativa"
    ) %>%
    opt_stylize(style = 6, color = "gray") %>%
    opt_table_outline() %>%
    tab_options(table.align = "left", table.width = px(700))
}

# Colapsa tokens por período em string para exibição no quadro.
# n_min = limiar exclusivo: inclui apenas n > n_min
# Portanto: n_min = 2 → n >= 3; n_min = 1 → n >= 2
colapsar_por_periodo <- function(df, termo_col, n_min = 1,
                                 nome_coluna = "Itens (freq.)") {
  termo_col <- rlang::ensym(termo_col)
  df %>%
    count(periodo, !!termo_col, sort = TRUE, name = "n") %>%
    group_by(periodo) %>%
    filter(n > n_min) %>%
    ungroup() %>%
    mutate(item = sprintf("%s (%d)", formatar_token(!!termo_col), n)) %>%
    group_by(periodo) %>%
    summarise(
      !!nome_coluna := str_c(item, collapse = "; "),
      .groups = "drop"
    ) %>%
    arrange(periodo)
}

# Função auxiliar para colapsar subconjunto com limiar específico
colapsar_subset <- function(df, termo_col, n_min, nome_coluna) {
  termo_col <- rlang::ensym(termo_col)
  df %>%
    count(periodo, !!termo_col, sort = TRUE, name = "n") %>%
    group_by(periodo) %>%
    filter(n > n_min) %>%
    ungroup() %>%
    mutate(item = sprintf("%s (%d)", formatar_token(!!termo_col), n)) %>%
    group_by(periodo) %>%
    summarise(!!nome_coluna := str_c(item, collapse = "; "), .groups = "drop") %>%
    arrange(periodo)
}

# Normaliza descritores de autores nas palavras-chave do formato
# "Sobrenome, Nome, Ano" para "Nome Sobrenome"
normalizar_autor_keyword <- function(keyword) {
  keyword <- str_remove(
    keyword,
    "\\s*[-–]\\s*(critica|vida|miseria|o capital|sao bernardo|triste|historia|guerra|republica).*$"
  )
  keyword <- str_remove(keyword, "\\s*\\.\\s*(?=[a-z]{2,}).*$")
  keyword <- str_remove(keyword, ",\\s*\\d{3,4}\\s*[-–]?\\s*\\d{0,4}\\s*$")
  keyword <- str_remove_all(keyword, "\\s*\\([^)]*\\)")
  partes  <- str_split(keyword, ",\\s*", simplify = TRUE)
  if (ncol(partes) >= 2 && str_trim(partes[1, 2]) != "") {
    keyword <- str_c(str_trim(partes[1, 2]), str_trim(partes[1, 1]), sep = " ")
  }
  keyword %>%
    stri_trans_general("Latin-ASCII") %>%
    str_to_title() %>%
    str_squish()
}

