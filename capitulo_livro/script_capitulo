  mutate(autor_normalizado = harmonizar_nome(formatar_token(palavra))) %>%
  group_by(autor_normalizado) %>%
  summarise(n = sum(n), .groups = "drop") %>%
  arrange(desc(n))

autores_comparados <- keywords_autores_freq_harm %>%
  filter(n >= 2) %>%
  rename(freq_kw = n) %>%
  full_join(
    unigramas_autores_harm %>%
      filter(n >= 2) %>%
      rename(freq_titulo = n),
    by = "autor_normalizado"
  ) %>%
  arrange(desc(coalesce(freq_kw, 0L)), desc(coalesce(freq_titulo, 0L))) %>%
  mutate(
    rank         = row_number(),
    freq_rel_kw  = freq_kw    / total_kw_geral,
    freq_rel_tit = freq_titulo / total_titulo_geral,
    fonte        = case_when(
      !is.na(freq_kw) & !is.na(freq_titulo) ~ "Ambas",
      !is.na(freq_kw)                        ~ "Só palavras-chave",
      TRUE                                   ~ "Só títulos"
    )
  )

