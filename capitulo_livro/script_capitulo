# 10.0b) Distribuição de frequências — dispersão do corpus
dist_freq_kw <- keywords_temas %>%
  count(n, name = "n_termos") %>%
  rename(frequencia = n) %>%
  arrange(frequencia) %>%
  mutate(
    fonte           = "Palavras-chave",
    pct_termos      = n_termos / sum(n_termos),
    ocorrencias     = frequencia * n_termos,
    pct_ocorrencias = ocorrencias / sum(ocorrencias)
  )

dist_freq_uni <- unigramas_temas %>%
  count(n, name = "n_termos") %>%
  rename(frequencia = n) %>%
  arrange(frequencia) %>%
  mutate(
    fonte           = "Unigramas (títulos)",
    pct_termos      = n_termos / sum(n_termos),
    ocorrencias     = frequencia * n_termos,
    pct_ocorrencias = ocorrencias / sum(ocorrencias)
  )

dist_freq_bi <- bigrams_freq %>%
  count(n, name = "n_termos") %>%
  rename(frequencia = n) %>%
  arrange(frequencia) %>%
  mutate(
    fonte           = "Bigramas (títulos)",
    pct_termos      = n_termos / sum(n_termos),
    ocorrencias     = frequencia * n_termos,
    pct_ocorrencias = ocorrencias / sum(ocorrencias)
  )

dist_freq_total <- bind_rows(dist_freq_kw, dist_freq_uni, dist_freq_bi)

dist_freq_faixas <- dist_freq_total %>%
  mutate(
    faixa = case_when(
      frequencia == 1                    ~ "1 (hapax)",
      frequencia == 2                    ~ "2",
      frequencia >= 3 & frequencia <= 5  ~ "3–5",
      frequencia >= 6 & frequencia <= 10 ~ "6–10",
      frequencia > 10                    ~ "> 10"
    ),
    faixa = factor(faixa, levels = c("1 (hapax)", "2", "3–5", "6–10", "> 10"))
  ) %>%
  group_by(fonte, faixa) %>%
  summarise(
    n_termos        = sum(n_termos),
    ocorrencias     = sum(ocorrencias),
    pct_termos      = sum(pct_termos),
    pct_ocorrencias = sum(pct_ocorrencias),
    .groups = "drop"
  ) %>%
  arrange(fonte, faixa)

