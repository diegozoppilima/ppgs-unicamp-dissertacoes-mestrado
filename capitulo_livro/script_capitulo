# 6) Tokenização de títulos
tokenizar <- function(df, coluna_texto, stop_lista) {
  coluna_texto <- rlang::ensym(coluna_texto)
  df %>%
    filter(!is.na(!!coluna_texto), !!coluna_texto != "") %>%
    unnest_tokens(
      palavra,
      !!coluna_texto,
      token = "regex",
      pattern = "[^[:alnum:]_]+"
    ) %>%
    filter(
      !is.na(palavra),
      palavra != "",
      !palavra %in% stop_lista,
      !str_detect(palavra, "[0-9]"),
      nchar(palavra) > 1
    )
}

